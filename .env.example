# ============================================================
# Tripscape Adventures — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ---- Supabase (already set by Lovable Cloud) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_PROJECT_ID=YOUR-PROJECT
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT

# ---- Supabase service role (REQUIRED for bookings, emails, admin writes) ----
# Server-only. Bypasses RLS. Dashboard → Project Settings → API → service_role key.
# Without this: booking creation, email sending, and admin save/delete will fail.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ---- Email delivery via Resend (REQUIRED for confirmation emails) ----
# Create a key at https://resend.com → API Keys. Verify your domain first (see go-live notes).
RESEND_API_KEY=re_xxx
EMAIL_FROM=Tripscape Adventures <bookings@tripscapetourism.com>
ADMIN_BOOKING_EMAIL=bookings@tripscapetourism.com
EMAIL_REPLY_TO=bookings@tripscapetourism.com

# ---- WhatsApp + site ----
# Digits only, full international format, no + or spaces.
WHATSAPP_NUMBER=971549930684
SITE_URL=https://tripscapetourism.com

# ---- Stripe (REQUIRED for online payments) ----
# Dashboard → Developers → API keys. Use test keys (sk_test_...) until you go live.
STRIPE_SECRET_KEY=sk_test_xxx
# Create a webhook endpoint pointing to https://YOUR-DOMAIN/api/stripe/webhook
# listening for "checkout.session.completed"; copy its signing secret here.
STRIPE_WEBHOOK_SECRET=whsec_xxx
